{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/condition-ir.schema.json",
  "title": "Power-mode condition IR + testcase traceability",
  "type": "object",
  "required": ["conditions", "test_cases"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Program or subsystem id (your naming convention)."
    },
    "revision": {
      "type": "string",
      "description": "Document/spec revision snapshot (Excel/Word)."
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" },
      "minItems": 1
    },
    "test_cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/test_case" },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "doc_pointer": {
      "type": "object",
      "required": ["file", "location"],
      "properties": {
        "file": { "type": "string", "examples": ["PowerMode_definition.xlsx", "SRS_Power_Mode.docx"] },
        "location": {
          "type": "string",
          "description": "Sheet!cell range, bookmark, section id, paragraph ref, etc.",
          "examples": ["Logic!R12:R15", "/Headings/Combined conditions/Case 07"]
        },
        "snippet": {
          "type": "string",
          "description": "Verbatim excerpt for audit / diff (~1–3 sentences)."
        }
      },
      "additionalProperties": false
    },
    "predicate": {
      "type": "object",
      "required": ["subject"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^P_[A-Za-z0-9_]+$",
          "description": "Stable id for this predicate within the testcase or condition."
        },
        "subject": {
          "type": "string",
          "description": "Canonical signal/state name (prefer glossary)."
        },
        "comparator": {
          "enum": ["==", "!=", "<", "<=", ">", ">=", "in", "between", "known", "unknown", "asserted_true", "asserted_false", "eventually", "within_ms"]
        },
        "value": {
          "description": "Compared value(s); type depends on subject."
        },
        "unit": { "type": "string", "examples": ["ms", "V", "-", "enum"] },
        "timing_notes": {
          "type": "string",
          "description": "Holds-before / timeout / debounce clarified for implementation."
        }
      },
      "additionalProperties": true
    },
    "condition": {
      "type": "object",
      "required": ["id", "title", "applies_to", "predicates", "source_evidence"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^COND_[A-Za-z0-9_]+$",
          "description": "Global condition identifier."
        },
        "title": { "type": "string", "description": "Short engineer-facing title." },
        "applies_to": {
          "type": "string",
          "description": "State machine slice: mode name, subsystem, boundary."
        },
        "predicates": {
          "type": "array",
          "items": { "$ref": "#/$defs/predicate" },
          "minItems": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["condition_ref", "doc_ref"], "description": "Link to COND_* id or textual doc anchor." },
              "ref_condition_id": { "type": "string" },
              "doc_pointer": { "$ref": "#/$defs/doc_pointer" },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "source_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/doc_pointer" },
          "minItems": 1
        },
        "unresolved_notes": {
          "type": "string",
          "description": "If trace is incomplete — block spec generation until resolved."
        }
      },
      "additionalProperties": false
    },
    "test_case": {
      "type": "object",
      "required": ["test_id", "linked_conditions", "ir_predicates_cover", "spec_trilingual_fields"],
      "properties": {
        "test_id": {
          "type": "string",
          "pattern": "^ST_PWR_[A-Za-z0-9_]+$",
          "description": "Stable id shared by spec doc and Google Test naming."
        },
        "linked_conditions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^COND_[A-Za-z0-9_]+$" },
          "minItems": 1
        },
        "neighbors_similar_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other test ids in same cluster — uniqueness check for Description."
        },
        "ir_predicates_cover": {
          "type": "array",
          "items": { "$ref": "#/$defs/predicate" },
          "description": "Full concrete Given as structured predicates."
        },
        "stimulus": {
          "type": "array",
          "items": { "$ref": "#/$defs/predicate" },
          "description": "Events when they are not folded into predicates (explicit When)."
        },
        "expected_observable": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assertion_summary"],
            "properties": {
              "assertion_summary": { "type": "string" },
              "maps_to_signals": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "description": "What must be asserted in test / spec Expectation section."
        },
        "spec_trilingual_fields": {
          "type": "object",
          "required": ["description_ja_or_en_choice", "given_text", "expectation_text"],
          "properties": {
            "description_ja_or_en_choice": {
              "type": "string",
              "description": "Primary customer narrative; JP customer → usually JA here."
            },
            "given_text": { "type": "string", "description": "Prose Given matching ir_predicates_cover." },
            "expectation_text": { "type": "string" },
            "description_alt_language": {
              "type": "string",
              "description": "Optional bilingual field (JP+EN) per your Style Guide."
            }
          },
          "additionalProperties": false
        },
        "gtest_fixture": {
          "type": "string",
          "description": "Target Google Test fixture / suite name hint."
        }
      },
      "additionalProperties": false
    }
  }
}
