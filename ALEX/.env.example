# Copy to .env and fill — NEVER commit .env (already in .gitignore).
# chmod 600 .env on the Ubuntu server.

# Azure client secret Value (not Secret ID)
M365_CLIENT_SECRET=

# Optional — override config.yaml / config.local.yaml without editing those files:
# M365_CLIENT_ID=
# M365_TENANT_ID=

# --- Ubuntu company server (ISMS-safe SSL) ---
# 1. Ask IT for corporate root CA (.pem) — see docs/IT_REQUEST_CHECKLIST.md
# 2. Copy to config/company-ca.pem on server
# 3. Uncomment and set absolute path (example for /home/tmc_ai_common/ALEX):
#
# REQUESTS_CA_BUNDLE=/home/tmc_ai_common/ALEX/config/company-ca.pem
# M365_CA_BUNDLE=/home/tmc_ai_common/ALEX/config/company-ca.pem
#
# Keep assist.m365.ssl_verify: true in config.yaml — do NOT use M365_SSL_VERIFY=false
