# Copy sang .env tren Ubuntu — KHONG commit .env
# chmod 600 .env

# Secret Azure (cot Value, KHONG phai Secret ID)
M365_CLIENT_SECRET=

# --- SSL mang cong ty (bat buoc de Sign in M365) ---
# Buoc 1: IT gui file root CA → dat tai config/company-ca.pem
# Buoc 2: Bo comment 2 dong duoi (sua path neu khac /home/tmc_ai_common/ALEX):

# REQUESTS_CA_BUNDLE=/home/tmc_ai_common/ALEX/config/company-ca.pem
# M365_CA_BUNDLE=/home/tmc_ai_common/ALEX/config/company-ca.pem

# client_id / tenant_id: sua trong config.yaml (IT cap)
# KHONG dat M365_SSL_VERIFY=false (vi pham ISMS)
